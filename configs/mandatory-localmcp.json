{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/user_data_rw"
      ],
      "compress": {
        "level": "medium"
      }
    },
    "pincher": {
      "command": "pincher",
      "args": [
        "--data-dir",
        "/tmp/pincher",
        "--http",
        "127.0.0.1:8080",
        "--trust-proxy"
      ],
      "reverseProxy": {
        "mount": "/pincher",
        "upstream": "http://127.0.0.1:8080"
      },
      "compress": {
        "level": "medium"
      }
    }
  }
}
