# zelosMCP environment overrides (loaded by the Makefile via `-include .env`).
# Copy to `.env` and edit by hand, or run `make init-env` for the interactive
# wizard that walks through the prompts and writes `.env` for you.

# Source tree exposed to MCP backends. Bind-mounted twice into the container:
# rw at /user_data_rw (filesystem MCP root) and ro at /user_data_ro (pincher
# index target / WORKDIR). Default $HOME/workspace covers cross-repo browsing
# and pincher's auto-scan without further configuration.
USER_DATA_ROOT=$HOME/workspace

# HTTP listen surface. 127.0.0.1 means only this Mac can reach :8000;
# 0.0.0.0 exposes it on the LAN.
ZELOSMCP_PORT=8000
ZELOSMCP_BIND_ADDR=127.0.0.1

# Dockerfile target. Default: corp-cert-aware multi-stage build.
# Set to `Dockerfile` if you're NOT behind a TLS-intercepting proxy
# and don't need the corporate root-cert injection.
DOCKERFILE=docker-tools/Dockerfile

# Build platform. Auto-detected by `make init-env` via `uname -m`.
# arm64/aarch64 → linux/arm64; x86_64 → linux/amd64.
PLATFORM=linux/arm64

# Backend config posted by `make load`. Point at configs/user-zelosmcp.json
# if `make init-env` wrote one for you (i.e. you opted out of any default
# backend). Otherwise the shipped default-zelosmcp.json runs every backend.
ZELOSMCP_CONFIG=configs/default-zelosmcp.json

# Cursor `.mdc` rule output: where it lands and what access mode it carries.
# Per-project (default): .cursor/rules/zelosmcp.mdc
# Global (all your Cursor projects): $HOME/.cursor/rules/zelosmcp.mdc
ZELOSMCP_RULE_FILE=.cursor/rules/zelosmcp.mdc
# Access mode: read-write (default) allows mutating tools with confirmation;
# read-only forbids any tool that may mutate state.
ZELOSMCP_RULE_ACCESS=read-write

# Host paths bind-mounted in. Override DOCKER_SOCK_FILE to ~/.rd/docker.sock
# when running Rancher Desktop without admin access (after `docker context
# use rancher-desktop`). See docs/setup-rancher-desktop.md.
KUBERNETES_CONFIG_FILE=$HOME/.kube/config
DOCKER_SOCK_FILE=/var/run/docker.sock

# Corporate root CA cert CN — only relevant when DOCKERFILE points at the
# corp-aware build. The CN must match a cert installed in your macOS
# keychain; `make cert` exports it as docker-tools/cert.pem at build time.
CORP_ROOT_AUTHORITY_CERT_NAME=Nike Root Authority NG

# Auto-chain toggles for `make load`. Set to 0 for fast CI loads where the
# per-repo index warm-up / Cursor rule regen aren't wanted. Pincher's
# WORKDIR-driven background auto-scan still kicks in either way.
ZELOSMCP_WARM_ON_LOAD=1
ZELOSMCP_RULE_ON_LOAD=1
